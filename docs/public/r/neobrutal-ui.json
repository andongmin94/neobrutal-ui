      "foreground": "oklch(0% 0 0)",
      "card": "oklch(96.79% 0.0654 102.26)",
      "card-foreground": "oklch(0% 0 0)",
      "popover": "oklch(96.79% 0.0654 102.26)",
      "popover-foreground": "oklch(0% 0 0)",
      "primary": "oklch(86.03% 0.176 92.36)",
