      "muted": "oklch(23.93% 0 0)",
      "muted-foreground": "oklch(100% 0 0)",
      "accent": "oklch(86.03% 0.176 92.36)",
      "accent-foreground": "oklch(0% 0 0)",
      "destructive": "oklch(63.68% 0.2078 25.33)",
